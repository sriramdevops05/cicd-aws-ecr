{
  "name": "cicd-demo-webapp",
  "version": "1.0.0",
  "description": "CI/CD demo web app — GitHub Actions + AWS ECR + EC2 + Gemini AI",
  "main": "app/server.js",
  "scripts": {
    "start":          "node app/server.js",
    "dev":            "nodemon app/server.js",
    "test":           "jest --forceExit",
    "test:coverage":  "jest --coverage --forceExit",
    "lint":           "eslint app/**/*.js --ext .js",
    "format:check":   "prettier --check 'app/**/*.js'"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint":    "^8.57.0",
    "jest":      "^29.7.0",
    "nodemon":   "^3.1.0",
    "prettier":  "^3.2.5",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["app/**/*.js", "!app/**/*.test.js"],
    "coverageReporters": ["text", "json-summary"],
    "coverageDirectory": "coverage"
  },
  "engines": { "node": ">=18.0.0" }
}
